<StatusMessage Message="@StatusMessage" />
<h3>Herstelcodes</h3>
<div class="alert alert-warning" role="alert">
    <p>
        <strong>Bewaar deze codes op een veilige plek.</strong>
    </p>
    <p>
        Als je je apparaat kwijt bent en geen herstelcodes hebt, verlies je toegang tot je account.
    </p>
</div>
<div class="row">
    <div class="col-md-12">
        @foreach (var recoveryCode in RecoveryCodes)
        {
            <div>
                <code class="recovery-code">@recoveryCode</code>
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public string[] RecoveryCodes { get; set; } = [];

    [Parameter]
    public string? StatusMessage { get; set; }
}
