@page "/Account/Manage/PersonalData"

@using Microsoft.AspNetCore.Identity
@using LotusPlanningApp.Data

@inject UserManager<ApplicationUser> UserManager
@inject IdentityRedirectManager RedirectManager

<PageTitle>Persoonlijke gegevens</PageTitle>

<StatusMessage />
<h3>Persoonlijke gegevens</h3>

<div class="row">
    <div class="col-md-6">
        <p>Je account bevat persoonlijke gegevens die je aan ons hebt gegeven. Op deze pagina kun je die gegevens downloaden of verwijderen.</p>
        <p>
            <strong>Het verwijderen van deze gegevens verwijdert je account definitief en kan niet worden hersteld.</strong>
        </p>
        <form action="Account/Manage/DownloadPersonalData" method="post">
            <AntiforgeryToken />
            <button class="btn btn-primary" type="submit">Downloaden</button>
        </form>
        <p>
            <a href="Account/Manage/DeletePersonalData" class="btn btn-danger">Verwijderen</a>
        </p>
    </div>
</div>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        var user  = await UserManager.GetUserAsync(HttpContext.User);
        if (user is null)
        {
            RedirectManager.RedirectToInvalidUser(UserManager, HttpContext);
        }
    }
}
